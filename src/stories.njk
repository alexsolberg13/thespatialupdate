---
layout: base.njk
title: Stories
description: "Every story on The Spatial Update, grouped by region."
permalink: /stories/
---

<style>
  .stories-wrap { max-width: 920px; margin: 0 auto; padding: 48px 24px 80px; }
  .stories-wrap h1 { font-size: 26px; font-weight: normal; color: var(--text-primary); margin-bottom: 8px; }
  .stories-intro { font-size: 13px; color: var(--text-secondary); font-family: Arial, sans-serif; margin-bottom: 36px; }

  .region-block { margin-bottom: 40px; }
  .region-title {
    font-size: 12px; font-weight: 500; color: var(--text-secondary); text-transform: uppercase;
    letter-spacing: 0.08em; font-family: Arial, sans-serif; margin-bottom: 14px;
    padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }

  .story-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
  .story-card {
    display: block; text-decoration: none; background: var(--surface);
    border: 1px solid var(--border); border-radius: 8px; padding: 18px 20px;
    transition: border-color 0.15s;
  }
  .story-card:hover { border-color: var(--accent); }
  .card-tag { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 8px; font-family: Arial, sans-serif; }
  .card-title { font-size: 15px; line-height: 1.4; color: var(--text-primary); margin-bottom: 8px; }
  .card-desc { font-size: 12px; line-height: 1.6; color: var(--text-body); font-family: Arial, sans-serif; }

  @media (max-width: 480px) {
    .story-cards { grid-template-columns: 1fr; }
  }
</style>

<div class="stories-wrap">
  <h1>Stories</h1>
  <div class="stories-intro">{{ stories.length }} stor{{ "y" if stories.length == 1 else "ies" }}, mapped.</div>

  {% for region, regionStories in stories | groupby("region") | dictsort %}
  <div class="region-block">
    <div class="region-title">{{ region }}</div>
    <div class="story-cards">
      {% for story in regionStories %}
        <a class="story-card" href="{{ story.url }}">
          <div class="card-tag">{{ story.tag }}</div>
          <div class="card-title">{{ story.title }}</div>
          <div class="card-desc">{{ story.description }}</div>
        </a>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>
