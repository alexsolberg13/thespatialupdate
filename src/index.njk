---
layout: base.njk
title: The Spatial Update
mapbox: true
---

<style>
  #body { display: flex; height: calc(100vh - 52px); height: calc(100dvh - 52px); overflow: hidden; }

  #sidebar {
    width: 300px; flex-shrink: 0; background: var(--surface);
    border-right: 1px solid var(--border); display: flex;
    flex-direction: column; overflow: hidden;
  }

  .search-wrap { padding: 14px 16px; border-bottom: 1px solid var(--border-light); }
  #search {
    width: 100%; background: var(--bg); border: 1px solid var(--border);
    border-radius: 5px; padding: 7px 10px; font-size: 12px;
    color: var(--text-primary); font-family: Arial, sans-serif; outline: none;
  }
  #search::placeholder { color: var(--text-muted); }
  #search:focus { border-color: var(--text-secondary); }

  .sidebar-meta { padding: 10px 16px 8px; border-bottom: 1px solid var(--border-light); }
  .sidebar-count { font-size: 11px; color: var(--text-secondary); font-family: Arial, sans-serif; }
  .sidebar-count span { color: var(--accent); }

  #story-list { overflow-y: auto; flex: 1; }
  #story-list::-webkit-scrollbar { width: 3px; }
  #story-list::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 2px; }

  .radar-toggle-wrap { padding: 10px 16px; border-top: 1px solid var(--border-light); flex-shrink: 0; }
  .radar-toggle {
    display: flex; align-items: center; gap: 7px; cursor: pointer; user-select: none;
    font-family: Arial, sans-serif; font-size: 11px; color: var(--text-secondary);
  }
  .radar-toggle input[type="checkbox"] {
    width: 12px; height: 12px; margin: 0; flex-shrink: 0;
    accent-color: var(--accent); cursor: pointer;
  }
  .radar-toggle-hint {
    font-size: 9px; color: var(--text-muted); margin-left: auto;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .radar-toggle.is-unavailable { opacity: 0.5; cursor: default; }
  .radar-toggle.is-unavailable input[type="checkbox"] { cursor: not-allowed; }

  .region-group { border-bottom: 1px solid var(--border-light); }
  .region-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 16px; cursor: pointer; user-select: none;
    transition: background 0.15s;
  }
  .region-header:hover { background: var(--bg); }
  .region-left { display: flex; align-items: center; gap: 8px; }
  .region-name { font-size: 11px; font-weight: 500; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; font-family: Arial, sans-serif; }
  .region-count { font-size: 10px; color: var(--text-muted); font-family: Arial, sans-serif; }
  .region-chevron {
    width: 0; height: 0; flex-shrink: 0;
    border-left: 4px solid transparent; border-right: 4px solid transparent;
    border-top: 5px solid var(--text-muted); transition: transform 0.2s;
  }
  .region-chevron.open { transform: rotate(180deg); }
  .region-stories { display: none; }
  .region-stories.open { display: block; }

  .story-item {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 16px 10px 24px; text-decoration: none;
    border-bottom: 1px solid var(--border-light); transition: background 0.15s;
  }
  .story-item:hover { background: var(--bg); }
  .story-item.active { background: var(--bg); border-left: 2px solid var(--accent); padding-left: 22px; }
  .item-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
  .item-body { flex: 1; min-width: 0; }
  .item-title { font-size: 13px; color: var(--text-primary); line-height: 1.4; margin-bottom: 3px; }
  .item-meta { display: flex; align-items: center; gap: 5px; }
  .item-tag { font-size: 10px; color: var(--text-secondary); font-family: Arial, sans-serif; }
  .item-type {
    font-size: 9px; font-family: Arial, sans-serif; font-weight: 500;
    padding: 1px 5px; border-radius: 2px; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .type-news     { background: #fdf2d6; color: #8a6b20; }
  .type-economy  { background: #dceaf6; color: #2a6aad; }
  .type-geography { background: #d0f3ee; color: #1a8a75; }
  .type-demographics { background: #fde8e6; color: #c0352a; }
  .type-military { background: #fde8e6; color: #c0352a; }

  #map { flex: 1; height: 100%; }

  @media (max-width: 768px) {
    #body { flex-direction: column; }
    #sidebar { width: 100%; height: 50vh; height: 50dvh; border-right: none; border-bottom: 1px solid var(--border); }
    #map { height: 50vh; height: 50dvh; flex: none; }
  }

  .mapboxgl-popup-content {
    background: var(--surface) !important; border: 1px solid var(--border);
    border-radius: 8px; padding: 0; font-family: Georgia, serif;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    width: 280px; max-width: calc(100vw - 32px); overflow: hidden;
  }
  .mapboxgl-popup-close-button { color: var(--text-muted); font-size: 18px; padding: 6px 10px; background: none; }
  .mapboxgl-popup-close-button:hover { color: var(--text-secondary); background: none; }
  .mapboxgl-popup-tip { border-top-color: var(--border) !important; }
  .popup-inner { padding: 16px 18px 18px; }
  .popup-tag { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 7px; font-family: Arial, sans-serif; }
  .popup-title { font-size: 15px; line-height: 1.4; color: var(--text-primary); margin-bottom: 10px; }
  .popup-desc { font-size: 12px; line-height: 1.65; color: var(--text-body); margin-bottom: 16px; font-family: Arial, sans-serif; }
  .popup-link {
    display: block; text-align: center; font-size: 12px; color: #1a1816;
    background: #e8c87a; padding: 9px 14px; border-radius: 4px;
    text-decoration: none; font-family: Arial, sans-serif;
    letter-spacing: 0.03em; transition: background 0.15s;
  }
  .popup-link:hover { background: #f0d88a; }
  .radar-meta { display: block; font-size: 11px; color: var(--text-secondary); font-family: Arial, sans-serif; margin-top: 4px; }
  .radar-disclaimer { display: block; font-size: 9px; color: var(--text-muted); font-family: Arial, sans-serif; margin-top: 8px; letter-spacing: 0.02em; }
</style>

<div id="body">
  <div id="sidebar">
    <div class="search-wrap">
      <input type="text" id="search" placeholder="Search stories..." autocomplete="off" />
    </div>
    <div class="sidebar-meta">
      <div class="sidebar-count" id="story-count"></div>
    </div>
    <div id="story-list"></div>
    <div class="radar-toggle-wrap">
      <label class="radar-toggle" id="radar-toggle-label" title="Automated GDELT signals — unverified">
        <input type="checkbox" id="radar-toggle-input" />
        <span>Geo Radar — live event signals · last 24h</span>
        <span class="radar-toggle-hint" id="radar-toggle-hint"></span>
      </label>
    </div>
  </div>
  <div id="map"></div>
</div>

<script>
  mapboxgl.accessToken = '{{ site.mapboxToken }}';

  const stories = {{ stories | dump | safe }};

  const markerColors = {
    gold: '#e8c87a',
    red:  '#e05a4e',
    teal: '#3ecfb2',
    blue: '#5b9bd5'
  };

  const homeCenter = [20, 25];
  const homeZoom   = 2.2;

  const isDarkMode = () => document.documentElement.getAttribute('data-theme') === 'dark';

  const fogLight = {
    color: 'rgb(220, 235, 248)', 'high-color': 'rgb(160, 200, 240)',
    'horizon-blend': 0.04, 'space-color': 'rgb(80, 120, 180)', 'star-intensity': 0
  };
  const fogDark = {
    color: 'rgb(20, 25, 40)', 'high-color': 'rgb(40, 60, 100)',
    'horizon-blend': 0.04, 'space-color': 'rgb(5, 8, 20)', 'star-intensity': 0.6
  };

  const map = new mapboxgl.Map({
    container: 'map',
    style: isDarkMode() ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11',
    center: homeCenter,
    zoom: homeZoom,
    minZoom: 1.5,
    projection: 'globe',
    attributionControl: false
  });

  map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');
  map.addControl(new mapboxgl.NavigationControl(), 'top-right');

  // ── Geo Radar (optional live GDELT signals, /leads/candidates.geojson) ──
  let radarData = null;
  let radarEnabled = false;

  function escRadar(s) {
    if (s == null) return '';
    return String(s).replace(/[&<>"']/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
  }

  // The geojson the GDELT pipeline writes doesn't currently include a
  // "category" property — infer conflict vs. cooperation defensively from
  // the synopsis text (which always says "in conflict" or "engaging in
  // cooperation"), falling back to a neutral color if neither is found.
  function deriveRadarCategory(p) {
    if (!p) return null;
    const raw = (p.category || '').toString().toLowerCase();
    if (raw === 'conflict' || raw === 'cooperation') return raw;
    const text = `${p.synopsis || ''} ${p.title || ''}`.toLowerCase();
    if (text.includes('engaging in cooperation')) return 'cooperation';
    if (text.includes('in conflict')) return 'conflict';
    return null;
  }

  function buildRadarPopupHTML(p) {
    p = p || {};
    const tag = p._category === 'conflict' ? 'Conflict signal'
      : p._category === 'cooperation' ? 'Cooperation signal'
      : 'Geo Radar signal';
    const title = p.headline || p.title || 'Unlabeled event';
    const lines = [];
    if (p.synopsis) lines.push(escRadar(p.synopsis));
    if (p.actors) lines.push(`<span class="radar-meta">${escRadar(p.actors)}</span>`);

    const stats = [];
    if (typeof p.mentions === 'number') stats.push(`${p.mentions} mentions`);
    const sources = Array.isArray(p.sources) ? p.sources.filter(Boolean) : [];
    if (sources.length) stats.push(`${sources.length} source${sources.length === 1 ? '' : 's'}`);
    if (typeof p.date === 'string' && p.date.length >= 8) {
      stats.push(`${p.date.slice(0, 4)}-${p.date.slice(4, 6)}-${p.date.slice(6, 8)}`);
    }
    if (stats.length) lines.push(`<span class="radar-meta">${stats.join(' · ')}</span>`);
    lines.push('<span class="radar-disclaimer">Automated GDELT signals — unverified</span>');

    const link = sources[0]
      ? `<a class="popup-link" href="${escRadar(sources[0])}" target="_blank" rel="noopener">View source →</a>`
      : '';

    return `
      <div class="popup-inner">
        <div class="popup-tag">${escRadar(tag)}</div>
        <div class="popup-title">${escRadar(title)}</div>
        <div class="popup-desc">${lines.join('<br>')}</div>
        ${link}
      </div>
    `;
  }

  function ensureRadarLayer() {
    if (!radarData) return;
    if (map.getSource('geo-radar')) {
      map.getSource('geo-radar').setData(radarData);
    } else {
      map.addSource('geo-radar', { type: 'geojson', data: radarData });
    }
    if (!map.getLayer('geo-radar-dots')) {
      map.addLayer({
        id: 'geo-radar-dots', type: 'circle', source: 'geo-radar',
        layout: { visibility: radarEnabled ? 'visible' : 'none' },
        paint: {
          'circle-color': ['coalesce', ['get', '_color'], markerColors.gold],
          'circle-radius': [
            'interpolate', ['linear'], ['coalesce', ['get', 'mentions'], 0],
            0, 4, 25, 5, 100, 7, 500, 9, 2000, 12
          ],
          'circle-opacity': 0.8,
          'circle-stroke-width': 1,
          'circle-stroke-color': 'rgba(255,255,255,0.2)'
        }
      });
    }
  }

  map.on('mouseenter', 'geo-radar-dots', () => { map.getCanvas().style.cursor = 'pointer'; });
  map.on('mouseleave', 'geo-radar-dots', () => { map.getCanvas().style.cursor = ''; });

  const radarPopup = new mapboxgl.Popup({ closeButton: true, maxWidth: '300px', offset: 10 });
  map.on('click', 'geo-radar-dots', (e) => {
    const f = e.features[0];
    radarPopup.setLngLat(f.geometry.coordinates.slice()).setHTML(buildRadarPopupHTML(f.properties)).addTo(map);
  });

  const radarInput = document.getElementById('radar-toggle-input');
  const radarLabel = document.getElementById('radar-toggle-label');
  const radarHint  = document.getElementById('radar-toggle-hint');

  // Probe for the feed once, as soon as the page loads (it's a small daily
  // file). This lets the toggle disable itself proactively if the GDELT
  // pipeline hasn't produced a file yet, rather than only failing after the
  // visitor tries to turn it on. The source/layer itself is still only
  // added to the map lazily, the first time the toggle is switched on.
  const radarFetch = fetch('/leads/candidates.geojson')
    .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(data => {
      (data && data.features || []).forEach(f => {
        const p = f.properties = f.properties || {};
        const cat = deriveRadarCategory(p);
        p._category = cat;
        p._color = cat === 'conflict' ? markerColors.red : cat === 'cooperation' ? markerColors.teal : markerColors.gold;
      });
      radarData = data;
      return data;
    })
    .catch(err => {
      console.warn('Geo Radar: candidates.geojson unavailable —', err && err.message ? err.message : err);
      radarInput.checked = false;
      radarInput.disabled = true;
      radarLabel.classList.add('is-unavailable');
      if (radarHint) radarHint.textContent = 'unavailable';
      throw err;
    });

  radarInput.addEventListener('change', () => {
    if (!radarInput.checked) {
      radarEnabled = false;
      if (map.getLayer('geo-radar-dots')) map.setLayoutProperty('geo-radar-dots', 'visibility', 'none');
      return;
    }
    radarEnabled = true;
    radarFetch.then(() => {
      if (!radarEnabled) return; // toggled off again before the fetch resolved
      ensureRadarLayer();
      if (map.getLayer('geo-radar-dots')) map.setLayoutProperty('geo-radar-dots', 'visibility', 'visible');
    }).catch(() => { radarEnabled = false; });
  });

  map.on('style.load', () => {
    map.setFog(isDarkMode() ? fogDark : fogLight);

    const geojson = {
      type: 'FeatureCollection',
      features: stories.map((s, i) => ({
        type: 'Feature',
        geometry: { type: 'Point', coordinates: s.coordinates },
        properties: { index: i, color: markerColors[s.color] || markerColors.gold }
      }))
    };

    map.addSource('stories', { type: 'geojson', data: geojson, generateId: true });

    map.addLayer({
      id: 'story-glow', type: 'circle', source: 'stories',
      paint: {
        'circle-radius': ['case', ['boolean', ['feature-state', 'hover'], false], 18, 14],
        'circle-color': ['get', 'color'],
        'circle-opacity': ['case', ['boolean', ['feature-state', 'hover'], false], 0.22, 0.15]
      }
    });

    map.addLayer({
      id: 'story-dots', type: 'circle', source: 'stories',
      paint: {
        'circle-radius': ['case', ['boolean', ['feature-state', 'hover'], false], 10, 7],
        'circle-color': ['get', 'color'],
        'circle-opacity': 0.9, 'circle-stroke-width': 1.5,
        'circle-stroke-color': 'rgba(255,255,255,0.12)'
      }
    });

    let hoveredId = null;
    map.on('mouseenter', 'story-dots', (e) => {
      map.getCanvas().style.cursor = 'pointer';
      if (hoveredId !== null) map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: false });
      hoveredId = e.features[0].id;
      map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: true });
    });
    map.on('mouseleave', 'story-dots', () => {
      map.getCanvas().style.cursor = '';
      if (hoveredId !== null) map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: false });
      hoveredId = null;
    });

    const popup = new mapboxgl.Popup({ closeButton: true, maxWidth: '300px', offset: 14 });

    map.on('click', 'story-dots', (e) => {
      const story = stories[e.features[0].properties.index];
      const coords = e.features[0].geometry.coordinates.slice();
      map.flyTo({ center: coords, zoom: 5, duration: 1000, essential: true });
      map.once('moveend', () => {
        popup.setLngLat(coords).setHTML(`
          <div class="popup-inner">
            <div class="popup-tag">${story.tag}</div>
            <div class="popup-title">${story.title}</div>
            <div class="popup-desc">${story.description}</div>
            <a class="popup-link" href="${story.url}">Open the full story →</a>
          </div>
        `).addTo(map);
      });
    });

    // Theme/style switches (see themechange listener below) wipe custom
    // sources & layers, so re-add Geo Radar if it was already toggled on.
    if (radarData) ensureRadarLayer();
  });

  document.addEventListener('themechange', (e) => {
    map.setStyle(e.detail.dark ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11');
  });

  // ── Sidebar ──────────────────────────────────────────────────
  const regions = {};
  stories.forEach((s, i) => {
    if (!regions[s.region]) regions[s.region] = [];
    regions[s.region].push({ ...s, index: i });
  });
  const sortedRegions = Object.keys(regions).sort();

  const storyList  = document.getElementById('story-list');
  const storyCount = document.getElementById('story-count');
  const searchInput = document.getElementById('search');
  let flyBackTimer = null;

  function buildSidebar(filter = '') {
    storyList.innerHTML = '';
    const q = filter.toLowerCase().trim();
    let total = 0;

    sortedRegions.forEach(regionName => {
      const regionStories = regions[regionName].filter(s =>
        !q || s.title.toLowerCase().includes(q) ||
        s.tag.toLowerCase().includes(q) ||
        s.type.toLowerCase().includes(q) ||
        s.region.toLowerCase().includes(q)
      );
      if (!regionStories.length) return;
      total += regionStories.length;

      const group = document.createElement('div');
      group.className = 'region-group';

      const header = document.createElement('div');
      header.className = 'region-header';
      header.innerHTML = `
        <div class="region-left">
          <span class="region-name">${regionName}</span>
          <span class="region-count">${regionStories.length}</span>
        </div>
        <div class="region-chevron open"></div>
      `;

      const storiesEl = document.createElement('div');
      storiesEl.className = 'region-stories open';

      regionStories.forEach(story => {
        const color = markerColors[story.color] || markerColors.gold;
        const item = document.createElement('a');
        item.className = 'story-item';
        item.href = story.url;
        item.innerHTML = `
          <div class="item-dot" style="background:${color}"></div>
          <div class="item-body">
            <div class="item-title">${story.title}</div>
            <div class="item-meta">
              <span class="item-tag">${story.tag}</span>
              <span class="item-type type-${story.type}">${story.type}</span>
            </div>
          </div>
        `;

        item.addEventListener('mouseenter', () => {
          item.classList.add('active');
          if (flyBackTimer) clearTimeout(flyBackTimer);
          map.flyTo({ center: story.coordinates, zoom: 5, duration: 1200, essential: true });
        });
        item.addEventListener('mouseleave', () => {
          item.classList.remove('active');
          flyBackTimer = setTimeout(() => {
            map.flyTo({ center: homeCenter, zoom: homeZoom, duration: 1000, essential: true });
          }, 300);
        });

        storiesEl.appendChild(item);
      });

      header.addEventListener('click', () => {
        const isOpen = storiesEl.classList.contains('open');
        storiesEl.classList.toggle('open', !isOpen);
        header.querySelector('.region-chevron').classList.toggle('open', !isOpen);
      });

      group.appendChild(header);
      group.appendChild(storiesEl);
      storyList.appendChild(group);
    });

    storyCount.innerHTML = `<span>${total}</span> stor${total !== 1 ? 'ies' : 'y'} on the map`;
  }

  buildSidebar();
  searchInput.addEventListener('input', e => buildSidebar(e.target.value));
</script>
