---
layout: base.njk
title: The Spatial Update
mapbox: true
---

{#
  Homepage — two views sharing one page, toggled in vanilla JS:
    1. Editorial landing (default): featured story, "Latest" row, continent tiles.
    2. Interactive map: continent switcher, story rail, Mapbox globe.
  The editorial content is server-rendered from stories.json; the map view,
  pills and rail are built client-side from the same data. See the
  design handoff in ../Organizing the main page layout/design_handoff_homepage/.
#}

<style>
  /* The redesign's palette is the site's dark theme (see base.njk tokens),
     so everything is expressed in CSS variables and adapts to light mode.
     A handful of decorative "night map" values are literal on purpose. */

  .stage { position: relative; height: calc(100vh - 52px); height: calc(100dvh - 52px); overflow: hidden; }

  /* ---- interactive map view (base layer) ---- */
  .mapwrap { position: absolute; inset: 0; display: flex; flex-direction: column; }

  .switch {
    height: 46px; background: var(--surface-alt); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 8px; padding: 0 16px; flex-shrink: 0;
    overflow-x: auto; scrollbar-width: none;
  }
  .switch::-webkit-scrollbar { display: none; }
  .homebtn {
    font-family: Arial, sans-serif; font-size: 11px; letter-spacing: 0.05em; color: var(--text-body);
    padding: 5px 12px 5px 8px; border-right: 1px solid var(--border); margin-right: 4px;
    cursor: pointer; white-space: nowrap; flex-shrink: 0; background: none;
  }
  .homebtn:hover { color: var(--accent); }
  .pills { display: flex; align-items: center; gap: 8px; }
  .pill {
    font-family: Arial, sans-serif; font-size: 11px; letter-spacing: 0.04em;
    padding: 5px 13px; border-radius: 20px; cursor: pointer; white-space: nowrap;
    border: 1px solid var(--border); color: var(--text-body); background: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .pill:hover { border-color: var(--accent); color: var(--accent); }
  .pill.active {
    background: var(--accent); color: var(--bg); border-color: var(--accent);
  }
  .pill.active:hover { color: var(--bg); }
  .sort { margin-left: auto; font-family: Arial, sans-serif; font-size: 11px; color: var(--text-muted); white-space: nowrap; padding-left: 12px; }

  .mapbody { flex: 1; display: flex; min-height: 0; position: relative; }

  .rail {
    width: 336px; flex-shrink: 0; background: var(--surface); border-right: 1px solid var(--border);
    display: flex; flex-direction: column; position: relative; z-index: 2; min-height: 0;
  }
  .searchbox-wrap { padding: 14px 16px; flex-shrink: 0; }
  .searchbox {
    width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 5px;
    padding: 7px 10px; font-family: Arial, sans-serif; font-size: 12px;
    color: var(--text-primary); outline: none;
  }
  .searchbox::placeholder { color: var(--text-muted); }
  .searchbox:focus { border-color: var(--text-secondary); }

  .timeline { flex: 1; overflow-y: auto; padding-bottom: 20px; min-height: 0; }
  .timeline::-webkit-scrollbar { width: 3px; }
  .timeline::-webkit-scrollbar-thumb { background: var(--scrollbar); }
  .rail-empty { padding: 20px 24px; font-family: Arial, sans-serif; font-size: 12px; color: var(--text-muted); }

  .month {
    font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); padding: 12px 16px 4px 24px;
  }
  .titem { display: block; padding: 10px 16px 12px 30px; position: relative; cursor: pointer; text-decoration: none; }
  .titem:hover, .titem.active { background: var(--surface-alt); }
  .tline { position: absolute; left: 20px; top: 0; bottom: 0; width: 1px; background: var(--border); }
  .tnode { position: absolute; left: 16px; top: 15px; width: 9px; height: 9px; border-radius: 50%; border: 2px solid var(--surface); }
  .ttitle { font-size: 13px; color: var(--text-primary); line-height: 1.4; }
  .tmeta { display: flex; align-items: center; gap: 6px; margin-top: 5px; }
  .treg { font-family: Arial, sans-serif; font-size: 10px; color: var(--text-secondary); }

  .tbadge {
    font-family: Arial, sans-serif; font-size: 9px; font-weight: 500; padding: 1px 5px;
    border-radius: 2px; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .badge-military    { background: #3a2320; color: #e0897e; }
  .badge-economy     { background: #1f2e3d; color: #7fb0e0; }
  .badge-geography   { background: #16342d; color: #5fd3bd; }
  .badge-news        { background: #322813; color: #d8b45e; }
  .badge-demographics { background: #322813; color: #d8b45e; }

  #map { flex: 1; min-height: 0; position: relative; z-index: 1; background: var(--bg); }

  /* Geo Radar toggle — pinned to the bottom of the rail (see JS below) */
  .radar-toggle-wrap { padding: 10px 16px; border-top: 1px solid var(--border-light); flex-shrink: 0; }
  .radar-toggle {
    display: flex; align-items: center; gap: 7px; cursor: pointer; user-select: none;
    font-family: Arial, sans-serif; font-size: 11px; color: var(--text-secondary);
  }
  .radar-toggle input[type="checkbox"] {
    width: 12px; height: 12px; margin: 0; flex-shrink: 0; accent-color: var(--accent); cursor: pointer;
  }
  .radar-toggle-hint {
    font-size: 9px; color: var(--text-muted); margin-left: auto;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .radar-toggle.is-unavailable { opacity: 0.5; cursor: default; }
  .radar-toggle.is-unavailable input[type="checkbox"] { cursor: not-allowed; }

  /* ---- editorial landing (overlay) ---- */
  .landing { position: absolute; inset: 0; background: var(--bg); overflow-y: auto; z-index: 20; }
  .landing::-webkit-scrollbar { width: 8px; }
  .landing::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 4px; }
  .landing[hidden] { display: none; }

  .land-inner { max-width: 1180px; margin: 0 auto; padding: 40px 40px 64px; display: flex; flex-direction: column; gap: 38px; }

  .feat { display: flex; gap: 26px; }
  .feat-text {
    flex: 1.4; background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    padding: 34px 36px; display: flex; flex-direction: column; justify-content: center; min-height: 260px;
  }
  .kicker { font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; }
  .feat-title { font-size: 30px; line-height: 1.22; color: var(--text-primary); margin-bottom: 14px; max-width: 560px; }
  .feat-desc { font-family: Arial, sans-serif; font-size: 14px; line-height: 1.65; color: var(--text-body); max-width: 520px; }
  .feat-meta { display: flex; align-items: center; gap: 8px; margin-top: 20px; }

  .feat-map {
    flex: 1; position: relative; background: #0d1420; border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden; min-height: 260px; cursor: pointer;
  }
  .feat-map:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .feat-sphere {
    position: absolute; left: 55%; top: 50%; transform: translate(-50%, -50%);
    width: 320px; height: 320px; border-radius: 50%;
    background: radial-gradient(circle at 38% 30%, #243450, #0f1826 60%, #0a1019);
    box-shadow: inset -22px -22px 55px rgba(0, 0, 0, 0.55);
  }
  .feat-dot { position: absolute; width: 9px; height: 9px; border-radius: 50%; }
  .explore {
    position: absolute; left: 18px; bottom: 16px; font-family: Arial, sans-serif; font-size: 12px;
    letter-spacing: 0.04em; color: #e4e0da; background: rgba(20, 18, 16, 0.72);
    padding: 8px 15px; border-radius: 22px; border: 1px solid #4a463f; transition: border-color 0.15s, color 0.15s;
  }
  .feat-map:hover .explore, .feat-map:focus-visible .explore { border-color: var(--accent); color: var(--accent); }

  .sec-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px; gap: 12px; }
  .sec-title { font-family: Arial, sans-serif; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-primary); }
  .sec-link { font-family: Arial, sans-serif; font-size: 11px; color: var(--text-secondary); cursor: pointer; white-space: nowrap; }
  .sec-link:hover { color: var(--accent); }

  .latest-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .lcard {
    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    padding: 18px 20px; cursor: pointer; transition: border-color 0.15s; text-decoration: none; display: block;
  }
  .lcard:hover { border-color: var(--accent); }
  .lcard-tag { font-family: Arial, sans-serif; font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); margin-bottom: 9px; }
  .lcard-title { font-size: 15px; line-height: 1.35; color: var(--text-primary); margin-bottom: 10px; }
  .lcard-date { font-family: Arial, sans-serif; font-size: 11px; color: var(--text-secondary); }

  .tiles { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .tile {
    background: var(--surface-alt); border: 1px solid var(--border); border-radius: 8px;
    padding: 17px 18px; cursor: pointer; transition: border-color 0.15s, background 0.15s;
  }
  .tile:hover { border-color: var(--accent); background: var(--surface); }
  .tile-name { font-family: Georgia, serif; font-size: 16px; color: var(--text-primary); }
  .tile-count { font-family: Arial, sans-serif; font-size: 11px; color: var(--text-secondary); margin-top: 6px; }

  /* ---- Mapbox popup ---- */
  .mapboxgl-popup-content {
    background: var(--surface) !important; border: 1px solid var(--border); border-radius: 8px;
    padding: 0; font-family: Georgia, serif; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    width: 280px; max-width: calc(100vw - 32px); overflow: hidden;
  }
  .mapboxgl-popup-close-button { color: var(--text-secondary); font-size: 18px; padding: 6px 10px; background: none; }
  .mapboxgl-popup-close-button:hover { color: var(--text-primary); background: none; }
  .mapboxgl-popup-tip { border-top-color: var(--border) !important; }
  .popup-inner { padding: 16px 18px 18px; }
  .popup-tag { font-family: Arial, sans-serif; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 7px; }
  .popup-title { font-size: 15px; line-height: 1.4; color: var(--text-primary); margin-bottom: 10px; }
  .popup-desc { font-family: Arial, sans-serif; font-size: 12px; line-height: 1.65; color: var(--text-body); margin-bottom: 16px; }
  .popup-link {
    display: block; text-align: center; font-family: Arial, sans-serif; font-size: 12px; color: #1a1816;
    background: #e8c87a; padding: 9px 14px; border-radius: 4px; text-decoration: none;
    letter-spacing: 0.03em; transition: background 0.15s;
  }
  .popup-link:hover { background: #f0d88a; }
  .radar-meta { display: block; font-size: 11px; color: var(--text-secondary); font-family: Arial, sans-serif; margin-top: 4px; }
  .radar-disclaimer { display: block; font-size: 9px; color: var(--text-muted); font-family: Arial, sans-serif; margin-top: 8px; letter-spacing: 0.02em; }

  /* ---- responsive ---- */
  @media (max-width: 900px) {
    .latest-grid { grid-template-columns: 1fr; }
    .tiles { grid-template-columns: repeat(2, 1fr); }
    .feat { flex-direction: column; }
    .land-inner { padding: 28px 20px 56px; gap: 30px; }
    .feat-title { font-size: 25px; }
  }

  @media (max-width: 768px) {
    .mapbody { flex-direction: column; }
    .rail { width: 100%; border-right: none; border-bottom: 1px solid var(--border); max-height: 42dvh; }
    #map { flex: 1; min-height: 240px; }
  }
</style>

{% set sorted = stories | sort(true, false, "order") %}
{% set featured = sorted[0] %}
{% set byCont = stories | groupby("continent") %}

<div class="stage" id="stage" data-view="landing">
  <!-- ===== interactive map view (base layer) ===== -->
  <div class="mapwrap">
    <div class="switch">
      <span class="homebtn" id="home-btn" role="button" tabindex="0">← Home</span>
      <div class="pills" id="pills"></div>
      <span class="sort">Sorted: Newest first</span>
    </div>
    <div class="mapbody">
      <div class="rail">
        <div class="searchbox-wrap">
          <input type="text" id="rail-search" class="searchbox" placeholder="Search stories…" autocomplete="off" />
        </div>
        <div class="timeline" id="timeline"></div>
        <div class="radar-toggle-wrap">
          <label class="radar-toggle" id="radar-toggle-label" title="Automated GDELT signals — unverified">
            <input type="checkbox" id="radar-toggle-input" />
            <span>Geo Radar — live event signals · last 24h</span>
            <span class="radar-toggle-hint" id="radar-toggle-hint"></span>
          </label>
        </div>
      </div>
      <div id="map"></div>
    </div>
  </div>

  <!-- ===== editorial landing (overlay) ===== -->
  <div class="landing" id="landing">
    <div class="land-inner">
      <div class="feat">
        <div class="feat-text">
          <div class="kicker">Featured · {{ featured.date }}</div>
          <div class="feat-title">{{ featured.title }}</div>
          <div class="feat-desc">{{ featured.description }}</div>
          <div class="feat-meta">
            <span class="treg">{{ featured.tag }}</span>
            <span class="tbadge badge-{{ featured.type }}">{{ featured.type }}</span>
          </div>
        </div>
        <div class="feat-map" id="feat-map" role="button" tabindex="0" aria-label="Explore the interactive map">
          <div class="feat-sphere"></div>
          <span class="feat-dot" style="left:48%;top:42%;background:#e05a4e;box-shadow:0 0 0 5px rgba(224,90,78,.2);"></span>
          <span class="feat-dot" style="left:54%;top:48%;background:#e8c87a;box-shadow:0 0 0 5px rgba(232,200,122,.2);"></span>
          <span class="feat-dot" style="left:44%;top:52%;background:#3ecfb2;box-shadow:0 0 0 5px rgba(62,207,178,.2);"></span>
          <span class="explore">Explore the interactive map →</span>
        </div>
      </div>

      <div>
        <div class="sec-head">
          <span class="sec-title">Latest</span>
          <span class="sec-link" data-open-all role="button" tabindex="0">View all {{ stories.length }} on the map →</span>
        </div>
        <div class="latest-grid">
          {% for s in sorted %}{% if loop.index0 >= 1 and loop.index0 <= 3 %}
          <a class="lcard" href="{{ s.url }}" data-open-all>
            <div class="lcard-tag">{{ s.tag }}</div>
            <div class="lcard-title">{{ s.title }}</div>
            <div class="lcard-date">{{ s.date }}</div>
          </a>
          {% endif %}{% endfor %}
        </div>
      </div>

      <div>
        <div class="sec-head"><span class="sec-title">Browse the archive by continent</span></div>
        <div class="tiles">
          {% for c in ["Middle East", "Americas", "Asia", "Europe", "Africa"] %}
          {% set count = (byCont[c] | default([])) | length %}
          <div class="tile" data-continent="{{ c }}" role="button" tabindex="0">
            <div class="tile-name">{{ c }}</div>
            <div class="tile-count">{{ count }} stor{{ "y" if count == 1 else "ies" }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  mapboxgl.accessToken = '{{ site.mapboxToken }}';

  const stories = {{ stories | dump | safe }};

  const markerColors = {
    gold: '#e8c87a',
    red:  '#e05a4e',
    teal: '#3ecfb2',
    blue: '#5b9bd5'
  };

  // Per-continent globe framing for the switcher pills + tiles.
  const continentMeta = {
    'all':         { center: [20, 25],  zoom: 2.2 },
    'Middle East': { center: [48, 27],  zoom: 3.6 },
    'Americas':    { center: [-72, 12], zoom: 2.7 },
    'Asia':        { center: [118, 26], zoom: 3.0 },
    'Europe':      { center: [20, 54],  zoom: 3.3 },
    'Africa':      { center: [22, 8],   zoom: 2.8 }
  };
  const continentOrder = ['Middle East', 'Americas', 'Asia', 'Europe', 'Africa'];
  const homeCenter = continentMeta.all.center;
  const homeZoom   = continentMeta.all.zoom;

  const isDarkMode = () => document.documentElement.getAttribute('data-theme') === 'dark';

  const fogLight = {
    color: 'rgb(220, 235, 248)', 'high-color': 'rgb(160, 200, 240)',
    'horizon-blend': 0.04, 'space-color': 'rgb(80, 120, 180)', 'star-intensity': 0
  };
  const fogDark = {
    color: 'rgb(20, 25, 40)', 'high-color': 'rgb(40, 60, 100)',
    'horizon-blend': 0.04, 'space-color': 'rgb(5, 8, 20)', 'star-intensity': 0.6
  };

  const map = new mapboxgl.Map({
    container: 'map',
    style: isDarkMode() ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11',
    center: homeCenter,
    zoom: homeZoom,
    minZoom: 1.5,
    projection: 'globe',
    attributionControl: false
  });

  map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');
  map.addControl(new mapboxgl.NavigationControl(), 'top-right');

  const popup = new mapboxgl.Popup({ closeButton: true, maxWidth: '300px', offset: 14 });

  function escapeHtml(value) {
    return String(value == null ? '' : value).replace(/[&<>"']/g, ch => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]
    ));
  }

  // ── View + continent state ───────────────────────────────────
  const stageEl    = document.getElementById('stage');
  const landingEl  = document.getElementById('landing');
  const pillsEl     = document.getElementById('pills');
  const timelineEl  = document.getElementById('timeline');
  const railSearch  = document.getElementById('rail-search');

  let view = 'landing';       // 'landing' | 'map'
  let continent = 'all';       // 'all' | one of continentOrder

  function setView(v) {
    view = v;
    stageEl.setAttribute('data-view', v);
    landingEl.hidden = (v !== 'landing');
    if (v === 'map') {
      // The map is always mounted behind the overlay, but resize defensively
      // in case the viewport changed while the landing was showing.
      setTimeout(() => map.resize(), 50);
    }
  }

  function openMap(toContinent) {
    setContinent(toContinent || 'all', false);
    setView('map');
    applyContinent(true);
  }

  function goHome() {
    setView('landing');
  }

  function setContinent(c, fly) {
    continent = c;
    updatePillStates();
    buildRail(railSearch.value);
    if (fly) applyContinent(true);
  }

  function applyContinent(fly) {
    if (map.getLayer('story-dots')) {
      const filter = continent === 'all' ? null : ['==', ['get', 'continent'], continent];
      map.setFilter('story-dots', filter);
      map.setFilter('story-glow', filter);
    }
    if (fly) flyToContinent();
  }

  function flyToContinent() {
    const m = continentMeta[continent] || continentMeta.all;
    map.flyTo({ center: m.center, zoom: m.zoom, duration: 900, essential: true });
  }

  function flyToStory(s) {
    map.flyTo({ center: s.coordinates, zoom: 5, duration: 1100, essential: true });
  }

  function showPopup(s) {
    const coords = s.coordinates.slice();
    map.flyTo({ center: coords, zoom: Math.max(map.getZoom(), 4.5), duration: 900, essential: true });
    map.once('moveend', () => {
      popup.setLngLat(coords).setHTML(`
        <div class="popup-inner">
          <div class="popup-tag">${escapeHtml(s.tag)}</div>
          <div class="popup-title">${escapeHtml(s.title)}</div>
          <div class="popup-desc">${escapeHtml(s.description)}</div>
          <a class="popup-link" href="${escapeHtml(s.url)}">Open the full story →</a>
        </div>
      `).addTo(map);
    });
  }

  // ── Continent switcher pills ─────────────────────────────────
  function continentCounts() {
    const counts = {};
    stories.forEach(s => { counts[s.continent] = (counts[s.continent] || 0) + 1; });
    return counts;
  }

  function buildPills() {
    const counts = continentCounts();
    const defs = [{ name: 'all', label: 'All · ' + stories.length }]
      .concat(continentOrder.map(n => ({ name: n, label: n + ' · ' + (counts[n] || 0) })));
    pillsEl.innerHTML = '';
    defs.forEach(def => {
      const el = document.createElement('button');
      el.type = 'button';
      el.className = 'pill' + (continent === def.name ? ' active' : '');
      el.dataset.continent = def.name;
      el.textContent = def.label;
      el.addEventListener('click', () => setContinent(def.name, true));
      pillsEl.appendChild(el);
    });
  }

  function updatePillStates() {
    pillsEl.querySelectorAll('.pill').forEach(el => {
      el.classList.toggle('active', el.dataset.continent === continent);
    });
  }

  // ── Story rail (reverse-chron, grouped by month) ─────────────
  function buildRail(filter = '') {
    const q = (filter || '').toLowerCase().trim();
    const sorted = stories.slice().sort((a, b) => (b.order || 0) - (a.order || 0));
    const filtered = sorted.filter(s => {
      if (continent !== 'all' && s.continent !== continent) return false;
      if (!q) return true;
      return [s.title, s.tag, s.type, s.continent, s.description]
        .some(v => (v || '').toLowerCase().includes(q));
    });

    timelineEl.innerHTML = '';
    if (!filtered.length) {
      const empty = document.createElement('div');
      empty.className = 'rail-empty';
      empty.textContent = q ? 'No stories match your search.' : 'No stories in this region yet.';
      timelineEl.appendChild(empty);
      return;
    }

    // Group consecutive items by their month label.
    const groups = [];
    filtered.forEach(s => {
      let g = groups.length && groups[groups.length - 1].label === s.date
        ? groups[groups.length - 1] : null;
      if (!g) { g = { label: s.date, items: [] }; groups.push(g); }
      g.items.push(s);
    });

    groups.forEach(group => {
      const monthEl = document.createElement('div');
      monthEl.className = 'month';
      monthEl.textContent = group.label || '';
      timelineEl.appendChild(monthEl);

      group.items.forEach(s => {
        const color = markerColors[s.color] || markerColors.gold;
        const type = s.type || 'news';
        const item = document.createElement('a');
        item.className = 'titem';
        item.href = s.url;
        item.innerHTML = `
          <div class="tline"></div>
          <span class="tnode" style="background:${color}"></span>
          <div class="ttitle">${escapeHtml(s.title)}</div>
          <div class="tmeta">
            <span class="treg">${escapeHtml(s.continent)}</span>
            <span class="tbadge badge-${escapeHtml(type)}">${escapeHtml(type)}</span>
          </div>
        `;
        item.addEventListener('mouseenter', () => { item.classList.add('active'); flyToStory(s); });
        item.addEventListener('mouseleave', () => { item.classList.remove('active'); flyToContinent(); });
        item.addEventListener('click', (e) => { e.preventDefault(); showPopup(s); });
        timelineEl.appendChild(item);
      });
    });
  }

  // ── Map data + interactions ──────────────────────────────────
  map.on('style.load', () => {
    map.setFog(isDarkMode() ? fogDark : fogLight);

    const geojson = {
      type: 'FeatureCollection',
      features: stories.map((s, i) => ({
        type: 'Feature',
        geometry: { type: 'Point', coordinates: s.coordinates },
        properties: { index: i, continent: s.continent, color: markerColors[s.color] || markerColors.gold }
      }))
    };

    map.addSource('stories', { type: 'geojson', data: geojson, generateId: true });

    map.addLayer({
      id: 'story-glow', type: 'circle', source: 'stories',
      paint: {
        'circle-radius': ['case', ['boolean', ['feature-state', 'hover'], false], 18, 14],
        'circle-color': ['get', 'color'],
        'circle-opacity': ['case', ['boolean', ['feature-state', 'hover'], false], 0.22, 0.15]
      }
    });

    map.addLayer({
      id: 'story-dots', type: 'circle', source: 'stories',
      paint: {
        'circle-radius': ['case', ['boolean', ['feature-state', 'hover'], false], 10, 7],
        'circle-color': ['get', 'color'],
        'circle-opacity': 0.9, 'circle-stroke-width': 1.5,
        'circle-stroke-color': 'rgba(255,255,255,0.12)'
      }
    });

    let hoveredId = null;
    map.on('mouseenter', 'story-dots', (e) => {
      map.getCanvas().style.cursor = 'pointer';
      if (hoveredId !== null) map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: false });
      hoveredId = e.features[0].id;
      map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: true });
    });
    map.on('mouseleave', 'story-dots', () => {
      map.getCanvas().style.cursor = '';
      if (hoveredId !== null) map.setFeatureState({ source: 'stories', id: hoveredId }, { hover: false });
      hoveredId = null;
    });

    map.on('click', 'story-dots', (e) => {
      showPopup(stories[e.features[0].properties.index]);
    });

    // Re-apply the active continent filter/framing (a theme switch re-runs
    // style.load and wipes custom sources/layers).
    applyContinent(false);
    if (radarData) ensureRadarLayer();
  });

  document.addEventListener('themechange', (e) => {
    map.setStyle(e.detail.dark ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11');
  });

  // ── Wire landing + navigation ────────────────────────────────
  buildPills();
  buildRail();

  document.getElementById('feat-map').addEventListener('click', () => openMap('all'));
  document.querySelectorAll('[data-open-all]').forEach(el => {
    el.addEventListener('click', (e) => { e.preventDefault(); openMap('all'); });
  });
  document.querySelectorAll('.tile[data-continent]').forEach(el => {
    el.addEventListener('click', () => openMap(el.dataset.continent));
  });

  document.getElementById('home-btn').addEventListener('click', goHome);
  // The shared header brand doubles as "return to landing" on the homepage.
  const brand = document.querySelector('.site-name');
  if (brand) { brand.style.cursor = 'pointer'; brand.addEventListener('click', goHome); }

  // Keyboard activation for the role="button" landing elements.
  [document.getElementById('feat-map'), document.getElementById('home-btn')]
    .concat(Array.from(document.querySelectorAll('[data-open-all][role="button"], .tile[data-continent]')))
    .forEach(el => {
      if (!el) return;
      el.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); el.click(); }
      });
    });

  railSearch.addEventListener('input', e => buildRail(e.target.value));

  // ── Geo Radar (optional live GDELT signals, /leads/candidates.geojson) ──
  let radarData = null;
  let radarEnabled = false;

  function deriveRadarCategory(p) {
    if (!p) return null;
    const raw = (p.category || '').toString().toLowerCase();
    if (raw === 'conflict' || raw === 'cooperation') return raw;
    const text = `${p.synopsis || ''} ${p.title || ''}`.toLowerCase();
    if (text.includes('engaging in cooperation')) return 'cooperation';
    if (text.includes('in conflict')) return 'conflict';
    return null;
  }

  function buildRadarPopupHTML(p) {
    p = p || {};
    const tag = p._category === 'conflict' ? 'Conflict signal'
      : p._category === 'cooperation' ? 'Cooperation signal'
      : 'Geo Radar signal';
    const title = p.headline || p.title || 'Unlabeled event';
    const lines = [];
    if (p.synopsis) lines.push(escapeHtml(p.synopsis));
    if (p.actors) lines.push(`<span class="radar-meta">${escapeHtml(p.actors)}</span>`);

    const stats = [];
    if (typeof p.mentions === 'number') stats.push(`${p.mentions} mentions`);
    const sources = Array.isArray(p.sources) ? p.sources.filter(Boolean) : [];
    if (sources.length) stats.push(`${sources.length} source${sources.length === 1 ? '' : 's'}`);
    if (typeof p.date === 'string' && p.date.length >= 8) {
      stats.push(`${p.date.slice(0, 4)}-${p.date.slice(4, 6)}-${p.date.slice(6, 8)}`);
    }
    if (stats.length) lines.push(`<span class="radar-meta">${stats.join(' · ')}</span>`);
    lines.push('<span class="radar-disclaimer">Automated GDELT signals — unverified</span>');

    const link = sources[0]
      ? `<a class="popup-link" href="${escapeHtml(sources[0])}" target="_blank" rel="noopener">View source →</a>`
      : '';

    return `
      <div class="popup-inner">
        <div class="popup-tag">${escapeHtml(tag)}</div>
        <div class="popup-title">${escapeHtml(title)}</div>
        <div class="popup-desc">${lines.join('<br>')}</div>
        ${link}
      </div>
    `;
  }

  function ensureRadarLayer() {
    if (!radarData) return;
    if (map.getSource('geo-radar')) {
      map.getSource('geo-radar').setData(radarData);
    } else {
      map.addSource('geo-radar', { type: 'geojson', data: radarData });
    }
    if (!map.getLayer('geo-radar-dots')) {
      map.addLayer({
        id: 'geo-radar-dots', type: 'circle', source: 'geo-radar',
        layout: { visibility: radarEnabled ? 'visible' : 'none' },
        paint: {
          'circle-color': ['coalesce', ['get', '_color'], markerColors.gold],
          'circle-radius': [
            'interpolate', ['linear'], ['coalesce', ['get', 'mentions'], 0],
            0, 4, 25, 5, 100, 7, 500, 9, 2000, 12
          ],
          'circle-opacity': 0.8,
          'circle-stroke-width': 1,
          'circle-stroke-color': 'rgba(255,255,255,0.2)'
        }
      });
    }
  }

  map.on('mouseenter', 'geo-radar-dots', () => { map.getCanvas().style.cursor = 'pointer'; });
  map.on('mouseleave', 'geo-radar-dots', () => { map.getCanvas().style.cursor = ''; });

  const radarPopup = new mapboxgl.Popup({ closeButton: true, maxWidth: '300px', offset: 10 });
  map.on('click', 'geo-radar-dots', (e) => {
    const f = e.features[0];
    radarPopup.setLngLat(f.geometry.coordinates.slice()).setHTML(buildRadarPopupHTML(f.properties)).addTo(map);
  });

  const radarInput = document.getElementById('radar-toggle-input');
  const radarLabel = document.getElementById('radar-toggle-label');
  const radarHint  = document.getElementById('radar-toggle-hint');

  const radarFetch = fetch('/leads/candidates.geojson')
    .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(data => {
      (data && data.features || []).forEach(f => {
        const p = f.properties = f.properties || {};
        const cat = deriveRadarCategory(p);
        p._category = cat;
        p._color = cat === 'conflict' ? markerColors.red : cat === 'cooperation' ? markerColors.teal : markerColors.gold;
      });
      radarData = data;
      return data;
    })
    .catch(err => {
      console.warn('Geo Radar: candidates.geojson unavailable —', err && err.message ? err.message : err);
      radarInput.checked = false;
      radarInput.disabled = true;
      radarLabel.classList.add('is-unavailable');
      if (radarHint) radarHint.textContent = 'unavailable';
      throw err;
    });

  radarInput.addEventListener('change', () => {
    if (!radarInput.checked) {
      radarEnabled = false;
      if (map.getLayer('geo-radar-dots')) map.setLayoutProperty('geo-radar-dots', 'visibility', 'none');
      return;
    }
    radarEnabled = true;
    radarFetch.then(() => {
      if (!radarEnabled) return;
      ensureRadarLayer();
      if (map.getLayer('geo-radar-dots')) map.setLayoutProperty('geo-radar-dots', 'visibility', 'visible');
    }).catch(() => { radarEnabled = false; });
  });
</script>
