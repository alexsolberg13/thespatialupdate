<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-value">~12%</div>
    <div class="stat-label">of global trade normally via the Red Sea</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">~10 days</div>
    <div class="stat-label">added by routing around Africa</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">70%</div>
    <div class="stat-label">drop in Suez Canal transits at the peak</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">~85%</div>
    <div class="stat-label">collapse in traffic at the port of Eilat</div>
  </div>
</div>

<div class="section-block">
  <div class="section-label">Map layers</div>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-routes" checked />
    <div class="layer-swatch" style="background:#5b9bd5"></div>
    Suez route
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-diversion" checked />
    <div class="layer-swatch" style="background:#e8c87a"></div>
    Cape diversion
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-ports" checked />
    <div class="layer-swatch" style="background:#3ecfb2; height:8px; width:8px; border-radius:50%; margin-right:2px;"></div>
    Ports &amp; terminals
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-attacks" checked />
    <div class="layer-swatch" style="background:#e05a4e; height:8px; width:8px; border-radius:50%; margin-right:2px;"></div>
    Notable incidents
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-threat" checked />
    <div class="layer-swatch" style="background:#e05a4e; opacity:0.6"></div>
    Threat zone
  </label>
</div>
