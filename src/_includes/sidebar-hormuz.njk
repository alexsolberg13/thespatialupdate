<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-value">21M</div>
    <div class="stat-label">barrels per day through the Strait</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">~20%</div>
    <div class="stat-label">of global oil supply</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">3.2km</div>
    <div class="stat-label">narrowest shipping lane width</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">75%</div>
    <div class="stat-label">of exports heading to Asia</div>
  </div>
</div>

<div class="section-block">
  <div class="section-label">Map layers</div>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-routes" checked />
    <div class="layer-swatch" style="background:#5b9bd5"></div>
    Tanker routes
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-pipelines" checked />
    <div class="layer-swatch" style="background:#e8c87a"></div>
    Bypass pipelines
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-ports" checked />
    <div class="layer-swatch" style="background:#3ecfb2; height:8px; width:8px; border-radius:50%; margin-right:2px;"></div>
    Export terminals
  </label>
  <label class="layer-toggle">
    <input type="checkbox" id="toggle-zones" checked />
    <div class="layer-swatch" style="background:#e05a4e; opacity:0.6"></div>
    Territorial zones
  </label>
</div>
