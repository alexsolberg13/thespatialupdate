<script>
  // Phase tab logic
  let activePhase = 'all';

  document.querySelectorAll('.phase-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.phase-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      activePhase = tab.dataset.phase;
      if (typeof applyFilters === 'function') applyFilters();
    });
  });

  // Layer toggle logic
  const layerToggles = {};
  document.querySelectorAll('.layer-toggle input[type="checkbox"]').forEach(cb => {
    const layerType = cb.id.replace('toggle-', '');
    layerToggles[layerType] = true;
    cb.addEventListener('change', () => {
      layerToggles[layerType] = cb.checked;
      if (typeof applyFilters === 'function') applyFilters();
    });
  });

  window.getActivePhase = () => activePhase;
  window.getLayerToggles = () => layerToggles;
</script>
