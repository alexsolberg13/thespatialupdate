---
layout: base.njk
mapbox: true
backLink: true
---

<style>
  .layout { display: flex; height: calc(100vh - 52px); overflow: hidden; }

  .sidebar {
    width: 380px; flex-shrink: 0; overflow-y: auto;
    background: var(--surface-alt); border-right: 1px solid var(--border); padding: 28px 26px;
  }
  .sidebar::-webkit-scrollbar { width: 3px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--scrollbar); }

  .story-label { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 10px; font-family: Arial, sans-serif; }
  h1 { font-size: 22px; line-height: 1.35; font-weight: normal; margin-bottom: 12px; color: var(--text-primary); }
  .byline { font-size: 11px; color: var(--text-muted); margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border); font-family: Arial, sans-serif; }
  .story-body { font-size: 14px; line-height: 1.8; color: var(--text-body); }
  .story-body p { margin-bottom: 14px; }
  .story-body a { color: var(--accent); text-decoration: none; }
  .story-body a:hover { text-decoration: underline; }

  /* ── Controls shared styles ── */
  .section-block { margin: 20px 0; padding: 14px 16px; background: var(--surface-raised); border-radius: 6px; border: 1px solid var(--border); }
  .section-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); margin-bottom: 10px; font-family: Arial, sans-serif; }

  /* ── Phase tabs ── */
  .phase-tabs { display: flex; gap: 6px; margin: 20px 0 0; }
  .phase-tab { flex: 1; padding: 8px 10px; text-align: center; font-size: 11px; font-family: Arial, sans-serif; border-radius: 5px; cursor: pointer; border: 1px solid var(--border); color: var(--text-secondary); background: var(--bg); transition: all 0.15s; }
  .phase-tab.active { border-color: var(--accent); color: var(--accent); background: var(--accent-bg); }
  .phase-name { font-weight: bold; display: block; margin-bottom: 2px; }
  .phase-date { font-size: 10px; color: var(--text-muted); }
  .phase-tab.active .phase-date { color: var(--accent); }

  /* ── Time slider ── */
  .current-date { font-size: 18px; font-weight: bold; color: var(--accent); margin-bottom: 12px; font-family: monospace; }
  input[type="range"] { width: 100%; accent-color: var(--accent); cursor: pointer; }
  .date-range { display: flex; justify-content: space-between; font-size: 10px; color: var(--text-muted); margin-top: 5px; font-family: Arial, sans-serif; }
  .event-count { font-size: 11px; color: var(--text-secondary); margin-top: 8px; font-family: Arial, sans-serif; }
  .event-count span { color: var(--accent); font-weight: bold; }

  /* ── Layer toggles ── */
  .layer-toggle { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; cursor: pointer; font-size: 12px; color: var(--text-body); font-family: Arial, sans-serif; }
  .layer-toggle:last-child { margin-bottom: 0; }
  .layer-toggle input[type="checkbox"] { accent-color: var(--accent); width: 14px; height: 14px; cursor: pointer; }
  .layer-swatch { width: 20px; height: 4px; border-radius: 2px; flex-shrink: 0; }

  /* ── Legend ── */
  .legend-row { display: flex; align-items: center; gap: 10px; margin-bottom: 7px; font-size: 12px; color: var(--text-body); font-family: Arial, sans-serif; }
  .legend-row:last-child { margin-bottom: 0; }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* ── Stat cards ── */
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 20px 0; }
  .stat-card { background: var(--surface-raised); border: 1px solid var(--border); border-radius: 6px; padding: 12px 14px; }
  .stat-value { font-size: 18px; font-weight: bold; color: var(--accent); font-family: Arial, sans-serif; margin-bottom: 3px; }
  .stat-label { font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.06em; font-family: Arial, sans-serif; line-height: 1.4; }

  /* ── Source note ── */
  .source-note { margin: 16px 0; padding: 10px 14px; background: var(--surface-raised); border-radius: 4px; border-left: 2px solid var(--border); font-size: 11px; color: var(--text-secondary); line-height: 1.6; font-family: Arial, sans-serif; }

  /* ── Related ── */
  .related { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); }
  .related-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); margin-bottom: 10px; font-family: Arial, sans-serif; }
  .related-link { display: block; text-decoration: none; padding: 10px 14px; background: var(--surface-raised); border: 1px solid var(--border); border-radius: 5px; margin-bottom: 8px; transition: border-color 0.15s; }
  .related-link:hover { border-color: var(--accent); }
  .related-tag { font-size: 10px; color: var(--accent); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; font-family: Arial, sans-serif; }
  .related-title { font-size: 13px; color: var(--text-primary); }

  /* ── Map ── */
  #map { flex: 1; height: 100%; }

  /* ── Popups ── */
  .mapboxgl-popup-content {
    background: var(--surface) !important; border: 1px solid var(--border);
    border-radius: 7px; padding: 0; font-family: Georgia, serif;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    min-width: 220px; max-width: 300px; overflow: hidden;
  }
  .mapboxgl-popup-close-button { color: var(--text-muted); font-size: 16px; padding: 5px 8px; background: none; }
  .mapboxgl-popup-close-button:hover { color: var(--text-secondary); background: none; }
  .mapboxgl-popup-tip { border-top-color: var(--border) !important; }
  .popup-inner { padding: 14px 16px 16px; }
  .popup-title { font-size: 14px; color: var(--text-primary); margin-bottom: 6px; line-height: 1.3; }
  .popup-date { font-size: 11px; color: var(--text-secondary); margin-bottom: 8px; font-family: Arial, sans-serif; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .popup-desc { font-size: 12px; line-height: 1.65; color: var(--text-body); }
</style>

<div class="layout">
  <div class="sidebar">

    <div class="story-label">{{ region }} · {{ type }}</div>
    <h1>{{ title }}</h1>
    <div class="byline">{{ byline }}</div>

    {# ── Story-specific controls slot ── #}
    {% include sidebarInclude %}

    <div class="story-body">
      {{ content | safe }}
    </div>

    {% if related %}
    <div class="related">
      <div class="related-label">Related maps</div>
      {% for item in related %}
      <a class="related-link" href="{{ item.url }}">
        <div class="related-tag">{{ item.tag }}</div>
        <div class="related-title">{{ item.title }}</div>
      </a>
      {% endfor %}
    </div>
    {% endif %}

  </div>

  <div id="map"></div>
</div>

<script>
  mapboxgl.accessToken = '{{ site.mapboxToken }}';

  const isDarkMode = () => document.documentElement.getAttribute('data-theme') === 'dark';

  const map = new mapboxgl.Map({
    container: 'map',
    style: isDarkMode() ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11',
    center: {{ coordinates | dump }},
    zoom: {{ zoom or 5 }},
    projection: '{{ projection or "mercator" }}'
  });

  map.addControl(new mapboxgl.NavigationControl(), 'top-right');

  map.on('style.load', () => {
    map.addSource('story-data', {
      type: 'geojson',
      data: './data.geojson'
    });

    {{ mapLayers | safe }}
  });

  {{ mapEvents | safe }}

  document.addEventListener('themechange', (e) => {
    map.setStyle(e.detail.dark ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/light-v11');
  });
</script>
